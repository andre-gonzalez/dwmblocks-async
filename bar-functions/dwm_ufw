#!/bin/sh

# A dwm_bar function that shows UFW firewall status
# Joe Standring <git@joestandring.com>
# GNU GPLv3

# Read /etc/ufw/ufw.conf directly (zero forks, no sudo)
while IFS='=' read -r key val; do
	case "$key" in
		ENABLED)
			[ "$val" = "yes" ] && exit 0
			echo "UFW "
			exit 0
			;;
	esac
done < /etc/ufw/ufw.conf
