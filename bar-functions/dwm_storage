#!/bin/sh

# A dwm_bar function to display information regarding system storage
# Based on dwm_resources by Joe Standring <git@joestandring.com>
# GNU GPLv3

# Handle click actions
case "$BLOCK_BUTTON" in
	1) notify-send "Disk Usage" "$(df -h --output=target,size,used,avail,pcent -x tmpfs -x devtmpfs | head -n 10)" ;;
	3) st -e tmux new-session -A -s ncdu sh -c 'limpar-disco; ncdu /' ;;
esac

# Calculate actual space used by /home directory (1 fork, unavoidable)
du_out=$(du -sh /home 2>/dev/null)
HOME_USED="${du_out%%	*}"

# Convert HOME_USED to GB with shell arithmetic (0 forks)
val="${HOME_USED%[A-Za-z]*}"
unit="${HOME_USED#"$val"}"
case "$unit" in
	K|k) HOME_USED_GB=0 ;;
	M|m) HOME_USED_GB=0 ;;
	G|g) HOME_USED_GB="${val%%.*}" ;;
	T|t) HOME_USED_GB=$(( ${val%%.*} * 1024 )) ;;
	*)   HOME_USED_GB=0 ;;
esac

# Detect filesystem type from /proc/mounts (0 forks)
filesystem=""
while read -r _dev mnt fstype _rest; do
	if [ "$mnt" = "/" ]; then
		filesystem="$fstype"
		break
	fi
done < /proc/mounts

if [ "$filesystem" = "btrfs" ]; then
	# Single btrfs call with raw bytes (1 fork, replaces 2 btrfs + 4 awk + 2 sed)
	BTRFS_OUT=$(btrfs filesystem usage -b / 2>/dev/null)
	DISK_USED_BYTES=""
	DISK_TOTAL_BYTES=""
	while IFS= read -r line; do
		case "$line" in
			*"Device size:"*)
				read -r DISK_TOTAL_BYTES <<-TRIMEOF
				${line##*:}
				TRIMEOF
				;;
			"    Used:"*)
				read -r DISK_USED_BYTES <<-TRIMEOF
				${line##*:}
				TRIMEOF
				;;
		esac
	done <<-BTRFSEOF
	$BTRFS_OUT
	BTRFSEOF

	if [ -n "$DISK_USED_BYTES" ] && [ -n "$DISK_TOTAL_BYTES" ] && [ "$DISK_TOTAL_BYTES" -gt 0 ] 2>/dev/null; then
		DISK_PERCENT=$((DISK_USED_BYTES * 100 / DISK_TOTAL_BYTES))
		DISK_USED_GB=$((DISK_USED_BYTES / 1073741824))
		DISK_TOTAL_GB=$((DISK_TOTAL_BYTES / 1073741824))
		AVAIL_GB=$((DISK_TOTAL_GB - DISK_USED_GB))
	else
		DISK_PERCENT=0
		AVAIL_GB=""
	fi
else
	# Non-btrfs: single df call, parse with read (1 fork, replaces df + tail + 4 awk)
	read -r _header
	read -r _dev DISK_TOTAL_BLOCKS DISK_USED_BLOCKS DISK_AVAIL_BLOCKS _rest <<-DFEOF
	$(df -P /)
	DFEOF

	if [ -n "$DISK_USED_BLOCKS" ] && [ -n "$DISK_TOTAL_BLOCKS" ] && [ "$DISK_TOTAL_BLOCKS" -gt 0 ] 2>/dev/null; then
		DISK_PERCENT=$((DISK_USED_BLOCKS * 100 / DISK_TOTAL_BLOCKS))
	else
		DISK_PERCENT=0
	fi

	if [ -n "$DISK_AVAIL_BLOCKS" ] && [ "$DISK_AVAIL_BLOCKS" -gt 0 ] 2>/dev/null; then
		AVAIL_GB=$((DISK_AVAIL_BLOCKS / 1048576))
	else
		AVAIL_GB=""
	fi
fi

# Display output (0 forks)
if [ -n "$HOME_USED_GB" ] && [ "$HOME_USED_GB" -lt 150 ] && [ "$HOME_USED_GB" -gt 0 ] 2>/dev/null; then
	if [ "$DISK_PERCENT" -gt 85 ] 2>/dev/null; then
		printf " %s%%\n" "$DISK_PERCENT"
	fi
else
	if [ "$DISK_PERCENT" -gt 85 ] 2>/dev/null; then
		printf "󰋜 %s ·  %s%%\n" "$HOME_USED" "$DISK_PERCENT"
	else
		printf "󰋜 %s\n" "$HOME_USED"
	fi
fi

# Storage warning notification
if [ -n "$AVAIL_GB" ] && [ "$AVAIL_GB" -ge 0 ] 2>/dev/null && [ "$AVAIL_GB" -lt 15 ] 2>/dev/null; then
	notify-send "HD cheio"
fi
