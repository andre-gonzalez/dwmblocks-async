#!/bin/sh

# A dwm_bar function to display information regarding system memory
# Based on dwm_resources by Joe Standring <git@joestandring.com>
# GNU GPLv3

case "$BLOCK_BUTTON" in
	1) st -e tmux new-session -A -s btop_memory btop -p 4 ;;
	3) notify-send "Top Memory Processes" "$(ps axo pid,comm,%mem --sort=-%mem | head -n 6)" ;;
esac

# Read /proc/meminfo with shell builtins (zero forks)
while IFS=': ' read -r key val _; do
	case "$key" in
		MemTotal) mem_total="$val" ;;
		MemAvailable) mem_avail="$val"; break ;;
	esac
done < /proc/meminfo

mem_used=$((mem_total - mem_avail))
mem_pct=$((mem_used * 100 / mem_total))

# Battery status via sysfs (zero forks)
BAT="BAT1"
[ -f "/sys/class/power_supply/$BAT/status" ] || BAT="BAT0"
threshold=75
if [ -f "/sys/class/power_supply/$BAT/status" ]; then
	read -r bat_status < "/sys/class/power_supply/$BAT/status"
	[ "$bat_status" = "Discharging" ] && threshold=15
fi

[ "$mem_pct" -le "$threshold" ] && exit 0

# Convert KB to human-readable with shell arithmetic (zero forks)
mem_gb=$((mem_used / 1048576))
if [ "$mem_gb" -ge 1 ]; then
	printf " %sG\n" "$mem_gb"
else
	printf " %sM\n" "$((mem_used / 1024))"
fi
