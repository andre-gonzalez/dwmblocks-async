#!/bin/sh

# Handle click actions
case "$BLOCK_BUTTON" in
1) st -e tmux new-session -A -s update 'nice -n 19 ionice -c 3 yay -Syyu --askremovemake --noconfirm' ;;
3) st -e tmux new-session -A -s packages 'fpf -U' ;;
esac

# Drop-in replacement for pacman-contrib's `checkupdates`: sync a private temp
# database (never touches /var/lib/pacman, so no partial-upgrade risk) and list
# pending repo updates. Only depends on pacman, pacman-conf and fakeroot.
CHECKUPDATES_DB="${TMPDIR:-/tmp}/checkup-db-$(id -u)/"
DBPath="$(pacman-conf DBPath 2>/dev/null || echo /var/lib/pacman/)"

checkupdates() {
	mkdir -p "$CHECKUPDATES_DB"
	[ -L "$CHECKUPDATES_DB/local" ] || ln -s "${DBPath%/}/local" "$CHECKUPDATES_DB" 2>/dev/null
	fakeroot -- pacman -Sy --dbpath "$CHECKUPDATES_DB" --logfile /dev/null >/dev/null 2>&1
	pacman -Qqu --dbpath "$CHECKUPDATES_DB" 2>/dev/null
}

cupd=$(checkupdates | wc -l)
if [ "$cupd" -gt 100 ]; then
	printf " %s\n" "$cupd"
else
	printf "\n"
fi

# Skip downloading updates on metered connections or on "Lopes" Wi-Fi
network=$(iwctl station wlan0 show | grep -Po 'Connected network \K.*' | awk '{$1=$1;print}')
metered=$(networkctl status | grep -c 'metered')

# if [ "$network" != "Lopes" ] && [ "$metered" -eq 0 ]; then
# 	# Pre-download pending repo upgrades into the package cache (no install)
# 	yay -Syuw --noconfirm >/dev/null 2>&1
# fi
exit 0
