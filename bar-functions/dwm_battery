#!/bin/sh

# Change BAT1 to whatever your battery is identified as. Typically BAT0 or BAT1
BAT="BAT1"

if [ ! -f "/sys/class/power_supply/$BAT/capacity" ]; then
	BAT="BAT0"
fi

BAT_PATH="/sys/class/power_supply/$BAT"

# Handle click actions
case "$BLOCK_BUTTON" in
	1)
		read -r CHARGE < "$BAT_PATH/capacity"
		read -r STATUS < "$BAT_PATH/status"
		read -r ENERGY_NOW < "$BAT_PATH/energy_now" 2>/dev/null || ENERGY_NOW=""
		read -r ENERGY_FULL < "$BAT_PATH/energy_full" 2>/dev/null || ENERGY_FULL=""
		read -r POWER_NOW < "$BAT_PATH/power_now" 2>/dev/null || POWER_NOW=""
		if [ -z "$POWER_NOW" ]; then
			read -r CURRENT_NOW < "$BAT_PATH/current_now" 2>/dev/null || CURRENT_NOW=""
			read -r VOLTAGE_NOW < "$BAT_PATH/voltage_now" 2>/dev/null || VOLTAGE_NOW=""
			read -r CHARGE_NOW < "$BAT_PATH/charge_now" 2>/dev/null || CHARGE_NOW=""
			read -r CHARGE_FULL < "$BAT_PATH/charge_full" 2>/dev/null || CHARGE_FULL=""
			if [ -n "$CURRENT_NOW" ] && [ -n "$VOLTAGE_NOW" ]; then
				POWER_NOW=$(( CURRENT_NOW * VOLTAGE_NOW / 1000000 ))
				ENERGY_NOW=$(( CHARGE_NOW * VOLTAGE_NOW / 1000000 ))
				ENERGY_FULL=$(( CHARGE_FULL * VOLTAGE_NOW / 1000000 ))
			fi
		fi
		WATTS=""
		TIME_LEFT=""
		if [ -n "$POWER_NOW" ] && [ "$POWER_NOW" -gt 0 ] 2>/dev/null; then
			w_whole=$((POWER_NOW / 1000000))
			w_frac=$(( (POWER_NOW % 1000000) / 100000 ))
			WATTS="${w_whole}.${w_frac}"
			if [ "$STATUS" = "Discharging" ] && [ -n "$ENERGY_NOW" ]; then
				h_whole=$((ENERGY_NOW / POWER_NOW))
				h_frac=$(( (ENERGY_NOW * 10 / POWER_NOW) % 10 ))
				TIME_LEFT="Time left: ${h_whole}.${h_frac}h"
			elif [ "$STATUS" = "Charging" ] && [ -n "$ENERGY_NOW" ] && [ -n "$ENERGY_FULL" ]; then
				REMAINING=$((ENERGY_FULL - ENERGY_NOW))
				h_whole=$((REMAINING / POWER_NOW))
				h_frac=$(( (REMAINING * 10 / POWER_NOW) % 10 ))
				TIME_LEFT="Time to full: ${h_whole}.${h_frac}h"
			fi
		fi
		MSG="Status: $STATUS\nCharge: ${CHARGE}%"
		[ -n "$WATTS" ] && MSG="$MSG\nPower: ${WATTS}W"
		[ -n "$TIME_LEFT" ] && MSG="$MSG\n$TIME_LEFT"
		notify-send "Battery" "$MSG"
		;;
esac

read -r CHARGE < "$BAT_PATH/capacity"
read -r STATUS < "$BAT_PATH/status"

# Determine icon based on charge percentage
if [ "$CHARGE" -ge 97 ] && [ "$STATUS" != "Discharging" ]; then
	exit 0
elif [ "$CHARGE" -ge 97 ]; then
	ICON=""
elif [ "$CHARGE" -le 20 ]; then
	ICON=" $CHARGE"
elif [ "$CHARGE" -le 40 ]; then
	ICON=" $CHARGE"
elif [ "$CHARGE" -le 60 ]; then
	ICON=""
elif [ "$CHARGE" -le 96 ]; then
	ICON=""
else
	ICON="?"
fi

# Display status with appropriate icon
if [ "$STATUS" = "Charging" ]; then
	printf "%s +\n" "$ICON"
else
	printf "%s\n" "$ICON"

	if [ "$CHARGE" -le 30 ]; then
		notify-send -u critical "Battery ${CHARGE}%"
	fi
fi
