#!/bin/sh

# Dependencies: bluetoothctl, pamixer

FLAG_FILE="/tmp/dwm_volume_show"

# Handle click actions
case "$BLOCK_BUTTON" in
	1) st -e tmux new-session -A -s bluetooth sh -c 'bluetoothctl info; exec bluetoothctl' ;;
	3) bluetoothctl disconnect ;;
	4) pamixer -i 5 ;;
	5) pamixer -d 5 ;;
esac

# Get connected devices (1 fork) — exit early if none
CONNECTED=$(bluetoothctl devices Connected 2>/dev/null)
if [ -z "$CONNECTED" ]; then
	printf "\n"
	exit 0
fi

# Only query default sink when devices exist (deferred — saves ~7ms when idle)
default_sink=""
if command -v pamixer >/dev/null 2>&1; then
	default_sink=$(pamixer --get-default-sink 2>/dev/null)
	case "$default_sink" in
		*[Dd]ummy*|*[Nn]ull*) default_sink="" ;;
	esac
fi

output=""
first=true

# Here-doc avoids pipe subshell so $output persists
while read -r _ mac _rest; do
	[ -z "$mac" ] && continue

	info=$(bluetoothctl info "$mac" 2>/dev/null)

	# Parse name and battery with shell builtins (0 forks vs 8 in original)
	name=""
	battery=""
	while IFS= read -r line; do
		case "$line" in
			*"Name: "*)
				name="${line#*Name: }"
				# Trim leading whitespace
				while case "$name" in " "*|"	"*) true ;; *) false ;; esac; do
					name="${name#?}"
				done
				;;
			*"Battery Percentage"*"("*")"*)
				tmp="${line#*(}"
				battery="${tmp%%)*}"
				;;
		esac
	done <<-INFOEOF
	$info
	INFOEOF

	[ -z "$name" ] && continue

	# Check if this device is the active Bluetooth audio sink
	audio_icon=""
	audio_vol=""
	if [ -n "$default_sink" ]; then
		case "$default_sink" in
			*[Bb]luez*)
				name_lower=$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')
				sink_lower=$(printf '%s' "$default_sink" | tr '[:upper:]' '[:lower:]')
				mac_lower=$(printf '%s' "$mac" | tr '[:upper:]' '[:lower:]')
				is_match=false
				case "$sink_lower" in
					*"$name_lower"*) is_match=true ;;
					*"$mac_lower"*)  is_match=true ;;
				esac

				if [ "$is_match" = "true" ]; then
					vol=$(pamixer --get-volume 2>/dev/null)
					muted=$(pamixer --get-mute 2>/dev/null)
					if [ -n "$vol" ]; then
						if [ "$muted" = "true" ] || [ "$vol" -eq 0 ]; then
							audio_icon="󰸈"
						elif [ "$vol" -le 33 ]; then
							audio_icon="󰖀"
						elif [ "$vol" -le 66 ]; then
							audio_icon="󰕾"
						else
							audio_icon=""
						fi
						[ -f "$FLAG_FILE" ] && audio_vol="$vol%"
					fi
				fi
				;;
		esac
	fi

	# Format device name
	case "$name" in
		"LE_WH-1000XM3"|"WH-1000XM3") device_str="XM3" ;;
		"Jabra Elite 3") device_str="Jabra" ;;
		"Mi Bluetooth Speaker") device_str="󰂰 Mi" ;;
		*) device_str="󰂰 $name" ;;
	esac

	# Append battery if low (skip for Mi speaker)
	case "$name" in
		"Mi Bluetooth Speaker") ;;
		*)
			if [ -n "$battery" ] && [ "$battery" -lt 60 ]; then
				device_str="$device_str $battery%"
			fi
			;;
	esac

	# Append audio icon and volume
	if [ -n "$audio_icon" ]; then
		device_str="$device_str $audio_icon"
		[ -n "$audio_vol" ] && device_str="$device_str $audio_vol"
	fi

	if [ "$first" = "true" ]; then
		output="$device_str"
		first=false
	else
		output="$output · $device_str"
	fi
done <<EOF
$CONNECTED
EOF

if [ -n "$output" ]; then
	printf "%s" "$output"
fi

printf "%s\n" "$SEP2"
